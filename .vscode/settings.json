{
  "[typst]": { "editor.formatOnSave": true },

  "tinymist.exportPdf": "onSave",
  "tinymist.rootPath": "${workspaceFolder}",
  "tinymist.systemFonts": false,

  "tinymist.previewFeature": "enable",
  "tinymist.semanticTokens": "enable",

  "cSpell.words": [
    "Typst",
    "typst",
    "luma",
    "comemo",
    "Reparsing",
    "emph",
    "breakability",
    "incrementality",
    "Libertinus",
    "pagebreak",
    "colbreak",
    "hline",
    "vline",
    "Palo"
  ]
}
